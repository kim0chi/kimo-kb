# Absolute path to the root of the external corpus (the evo-work repo).
# The app reads markdown from here; it NEVER copies, moves, or writes to it.
# Copy this file to `.env` and adjust if your path differs.
KB_CONTENT_ROOT=/home/evo-benedict/Documents/evo-work

# Optional: override the local state DB path (default: <project>/data/kb.sqlite).
# KB_STATE_DB=/home/evo-benedict/Documents/kb/data/kb.sqlite

# The notebook library: a directory scanned for kb.json manifests (folders) and
# *.kb.json reference manifests (external roots, like the SI Handbook in evo-work).
# If empty/missing, the app falls back to a built-in SI notebook using KB_CONTENT_ROOT.
KB_LIBRARY=/home/evo-benedict/Documents/knowledge
